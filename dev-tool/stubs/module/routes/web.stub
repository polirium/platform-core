<?php

use Illuminate\Support\Facades\Route;

Route::prefix(admin_prefix())
    ->middleware(['web', 'core'])
    ->namespace('{Module}\Http\Controllers')
    ->group(function () {
        Route::prefix('{-names}')->name('{-names}.')->group(function () {
              Route::get('', '{Name}Controller@index')->name('index');
        });
    });
