<?php

namespace {Module}\Providers;

use Polirium\Core\Support\Providers\PoliriumBaseServiceProvider;
use Polirium\Core\Base\Helpers\BaseHelper;

class {Name}ServiceProvider extends PoliriumBaseServiceProvider
{
    public function boot(): void
    {
        $this
            ->setNamespace('{types}/{-name}')
            ->loadConfigurations(['{module}'])
              ->loadViews()
            ->loadTranslations()
            ->loadRoutes(['web'])
            ->loadMigrations();
    }

    public function register()
    {
         BaseHelper::autoload(__DIR__ . '/../../helpers');
    }
}
